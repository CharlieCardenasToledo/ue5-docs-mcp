# Normalize line endings to LF on commit
* text=auto eol=lf

# Markdown
*.md text eol=lf
*.txt text eol=lf

# Python
*.py text eol=lf

# YAML / JSON / TOML
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Mark large generated files as binary to avoid diffs
GUIDE_BOOK.md binary
